<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0"
            prefWidth="712.0"
            style="-fx-background-color: #F4FFF0;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.mental_health_therapy_center.controller.TherapySessionController">

    <children>

        <!-- HEADER -->

        <Label alignment="CENTER"
               layoutX="25.0"
               layoutY="20.0"
               prefHeight="55.0"
               prefWidth="660.0"
               style="-fx-background-color: #0B6E0B;
                      -fx-background-radius: 18;"
               text="THERAPY SESSIONS"
               textFill="WHITE">

            <font>
                <Font name="System Bold" size="26.0"/>
            </font>

        </Label>

        <!-- FORM -->

        <VBox layoutX="25.0"
              layoutY="95.0"
              prefHeight="330.0"
              prefWidth="660.0"
              spacing="15.0"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-border-color: #D6EFD2;
                     -fx-border-radius: 20;
                     -fx-border-width: 2;">

            <children>

                <!-- ROW 1 -->

                <HBox spacing="15.0"
                      style="-fx-padding: 20 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Session ID"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtSessionId"
                                           editable="false"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Auto generated"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Session Name"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtSessionName"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Enter session name"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 2 -->

                <HBox spacing="15.0"
                      style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Patient"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <ComboBox fx:id="cmbPatient"
                                          prefHeight="38.0"
                                          prefWidth="280.0"
                                          promptText="Select patient"
                                          style="-fx-background-color: #F8FFF8;
                                                 -fx-border-color: #A5D6A7;
                                                 -fx-border-radius: 10;
                                                 -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Program"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <ComboBox fx:id="cmbProgram"
                                          prefHeight="38.0"
                                          prefWidth="280.0"
                                          promptText="Select program"
                                          style="-fx-background-color: #F8FFF8;
                                                 -fx-border-color: #A5D6A7;
                                                 -fx-border-radius: 10;
                                                 -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 3 -->

                <HBox spacing="15.0"
                      style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Therapist"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <ComboBox fx:id="cmbTherapist"
                                          prefHeight="38.0"
                                          prefWidth="280.0"
                                          promptText="Select therapist"
                                          style="-fx-background-color: #F8FFF8;
                                                 -fx-border-color: #A5D6A7;
                                                 -fx-border-radius: 10;
                                                 -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Session Date"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <DatePicker fx:id="datePicker"
                                            prefHeight="38.0"
                                            prefWidth="280.0"
                                            style="-fx-background-color: #F8FFF8;
                                                   -fx-border-color: #A5D6A7;
                                                   -fx-border-radius: 10;
                                                   -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </children>

        </VBox>

        <!-- BUTTONS -->

        <HBox alignment="CENTER"
              layoutX="25.0"
              layoutY="450.0"
              prefHeight="50.0"
              prefWidth="660.0"
              spacing="20.0">

            <children>

                <Button fx:id="btnAdd"
                        prefHeight="42.0"
                        prefWidth="140.0"
                        style="-fx-background-color: #0B6E0B;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;"
                        text="Add Session"/>

                <Button fx:id="btnUpdate"
                        prefHeight="42.0"
                        prefWidth="140.0"
                        style="-fx-background-color: #7CCB6B;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;"
                        text="Update"/>

                <Button fx:id="btnDelete"
                        prefHeight="42.0"
                        prefWidth="140.0"
                        style="-fx-background-color: #D62828;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;"
                        text="Delete"/>

                <Button fx:id="btnClear"
                        prefHeight="42.0"
                        prefWidth="140.0"
                        style="-fx-background-color: #444444;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;"
                        text="Clear"/>

            </children>

        </HBox>

        <!-- TABLE -->

        <TableView fx:id="tblSessions"
                   layoutX="25.0"
                   layoutY="525.0"
                   prefHeight="100.0"
                   prefWidth="660.0"
                   style="-fx-background-color: white;
                          -fx-border-color: #D6EFD2;
                          -fx-border-width: 2;
                          -fx-border-radius: 15;
                          -fx-background-radius: 15;">

            <columns>

                <TableColumn fx:id="colSessionId"
                             prefWidth="80.0"
                             text="ID"/>

                <TableColumn fx:id="colSessionName"
                             prefWidth="120.0"
                             text="Session"/>

                <TableColumn fx:id="colPatientName"
                             prefWidth="120.0"
                             text="Patient"/>

                <TableColumn fx:id="colProgramName"
                             prefWidth="120.0"
                             text="Program"/>

                <TableColumn fx:id="colTherapistName"
                             prefWidth="120.0"
                             text="Therapist"/>

                <TableColumn fx:id="colDate"
                             prefWidth="100.0"
                             text="Date"/>

            </columns>

        </TableView>

    </children>

</AnchorPane>