<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="650.0" prefWidth="712.0"
            style="-fx-background-color: #F5F7FA;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.mental_health_therapy_center.controller.AdminLayoutController">

    <children>

        <VBox alignment="TOP_CENTER"
              prefHeight="650.0"
              prefWidth="712.0"
              spacing="18"
              style="-fx-padding: 20;">

            <children>

                <!-- HEADER -->
                <HBox alignment="CENTER"
                      prefHeight="60.0"
                      prefWidth="670.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">

                    <children>
                        <Label text="ADMIN DASHBOARD"
                               style="-fx-text-fill: #2E7D32;
                                      -fx-font-size: 28px;
                                      -fx-font-weight: bold;">
                            <font>
                                <Font name="System Bold" size="28.0"/>
                            </font>
                        </Label>
                    </children>

                </HBox>

                <!-- MAIN CHART -->
                <HBox alignment="CENTER"
                      prefHeight="280.0"
                      prefWidth="670.0">

                    <children>

                        <AreaChart fx:id="therapyOverviewChart"
                                   prefHeight="270.0"
                                   prefWidth="670.0"
                                   style="-fx-background-color: white;
                                          -fx-background-radius: 18;
                                          -fx-padding: 10;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">

                            <xAxis>
                                <CategoryAxis fx:id="xAxisOverview" side="BOTTOM"/>
                            </xAxis>

                            <yAxis>
                                <NumberAxis fx:id="yAxisOverview" side="LEFT"/>
                            </yAxis>

                        </AreaChart>

                    </children>

                </HBox>

                <!-- LOWER SECTION -->
                <HBox alignment="CENTER"
                      prefHeight="260.0"
                      prefWidth="670.0"
                      spacing="18">

                    <children>

                        <!-- SESSION CHART -->
                        <VBox alignment="CENTER"
                              prefHeight="250.0"
                              prefWidth="390.0"
                              spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-padding: 12;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">

                            <children>

                                <Label text="Session Statistics"
                                       style="-fx-text-fill: #2E7D32;
                                              -fx-font-size: 18px;
                                              -fx-font-weight: bold;"/>

                                <LineChart fx:id="sessionChart"
                                           prefHeight="200.0"
                                           prefWidth="360.0">

                                    <xAxis>
                                        <CategoryAxis fx:id="xAxisSession"/>
                                    </xAxis>

                                    <yAxis>
                                        <NumberAxis fx:id="yAxisSession"/>
                                    </yAxis>

                                </LineChart>

                            </children>

                        </VBox>

                        <!-- QUICK ACTIONS -->
                        <VBox alignment="CENTER"
                              prefHeight="250.0"
                              prefWidth="250.0"
                              spacing="15"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-padding: 15;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">

                            <children>

                                <!-- TOP ICON ROW -->
                                <HBox alignment="CENTER"
                                      spacing="12">

                                    <children>

                                        <!-- USERS -->
                                        <Pane fx:id="paneUsers"
                                              prefHeight="90.0"
                                              prefWidth="90.0"
                                              onMouseClicked="#paneUsersOnAction"
                                              style="-fx-background-color: #4CAF50;
                                                     -fx-background-radius: 16;
                                                     -fx-cursor: hand;">

                                            <children>

                                                <ImageView fitHeight="38.0"
                                                           fitWidth="38.0"
                                                           layoutX="26.0"
                                                           layoutY="14.0">

                                                    <image>
                                                        <Image url="@../assets/icons8-user-50.png"/>
                                                    </image>

                                                </ImageView>

                                                <Label layoutX="25.0"
                                                       layoutY="58.0"
                                                       text="Users"
                                                       style="-fx-text-fill: white;
                                                              -fx-font-weight: bold;"/>

                                            </children>

                                        </Pane>

                                        <!-- THERAPISTS -->
                                        <Pane fx:id="paneTherapists"
                                              prefHeight="90.0"
                                              prefWidth="90.0"
                                              onMouseClicked="#paneTherapistsOnAction"
                                              style="-fx-background-color: #66BB6A;
                                                     -fx-background-radius: 16;
                                                     -fx-cursor: hand;">

                                            <children>

                                                <ImageView fitHeight="38.0"
                                                           fitWidth="38.0"
                                                           layoutX="26.0"
                                                           layoutY="14.0">

                                                    <image>
                                                        <Image url="@../assets/icons8-doctor-50.png"/>
                                                    </image>

                                                </ImageView>

                                                <Label layoutX="13.0"
                                                       layoutY="58.0"
                                                       text="Therapists"
                                                       style="-fx-text-fill: white;
                                                              -fx-font-weight: bold;"/>

                                            </children>

                                        </Pane>

                                    </children>

                                </HBox>

                                <!-- SECOND ICON ROW -->
                                <HBox alignment="CENTER"
                                      spacing="12">

                                    <children>

                                        <!-- PATIENTS -->
                                        <Pane fx:id="panePatients"
                                              prefHeight="90.0"
                                              prefWidth="90.0"
                                              onMouseClicked="#panePatientsOnAction"
                                              style="-fx-background-color: #81C784;
                                                     -fx-background-radius: 16;
                                                     -fx-cursor: hand;">

                                            <children>

                                                <ImageView fitHeight="38.0"
                                                           fitWidth="38.0"
                                                           layoutX="26.0"
                                                           layoutY="14.0">

                                                    <image>
                                                        <Image url="@../assets/icons8-patient-64.png"/>
                                                    </image>

                                                </ImageView>

                                                <Label layoutX="18.0"
                                                       layoutY="58.0"
                                                       text="Patients"
                                                       style="-fx-text-fill: white;
                                                              -fx-font-weight: bold;"/>

                                            </children>

                                        </Pane>

                                        <!-- PROGRAMS -->
                                        <Pane fx:id="panePrograms"
                                              prefHeight="90.0"
                                              prefWidth="90.0"
                                              onMouseClicked="#paneProgramsOnAction"
                                              style="-fx-background-color: #43A047;
                                                     -fx-background-radius: 16;
                                                     -fx-cursor: hand;">

                                            <children>

                                                <ImageView fitHeight="38.0"
                                                           fitWidth="38.0"
                                                           layoutX="26.0"
                                                           layoutY="14.0">

                                                    <image>
                                                        <Image url="@../assets/icons8-program-48.png"/>
                                                    </image>

                                                </ImageView>

                                                <Label layoutX="14.0"
                                                       layoutY="58.0"
                                                       text="Programs"
                                                       style="-fx-text-fill: white;
                                                              -fx-font-weight: bold;"/>

                                            </children>

                                        </Pane>

                                    </children>

                                </HBox>

                                <!-- BUTTONS -->
                                <Button fx:id="btnPayments"
                                        onAction="#btnPaymentsOnAction"
                                        prefHeight="36.0"
                                        prefWidth="190.0"
                                        style="-fx-background-color: #2E7D32;
                                               -fx-text-fill: white;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 20;"
                                        text="Track Payments"/>

                                <Button fx:id="btnReports"
                                        onAction="#btnReportsOnAction"
                                        prefHeight="36.0"
                                        prefWidth="190.0"
                                        style="-fx-background-color: white;
                                               -fx-border-color: #2E7D32;
                                               -fx-border-width: 2;
                                               -fx-text-fill: #2E7D32;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 20;
                                               -fx-border-radius: 20;"
                                        text="Financial Reports"/>

                                <Button fx:id="btnHistory"
                                        onAction="#btnHistoryOnAction"
                                        prefHeight="36.0"
                                        prefWidth="190.0"
                                        style="-fx-background-color: white;
                                               -fx-border-color: #2E7D32;
                                               -fx-border-width: 2;
                                               -fx-text-fill: #2E7D32;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 20;
                                               -fx-border-radius: 20;"
                                        text="Patient History"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>