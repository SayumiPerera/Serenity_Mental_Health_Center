<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<AnchorPane
        fx:id="root"
        prefHeight="680.0"
        prefWidth="740.0"
        style="-fx-background-color: #F5F7FA;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="lk.ijse.mental_health_therapy_center.controller.AdminLayoutController">

    <children>

        <VBox
                alignment="TOP_CENTER"
                prefHeight="680.0"
                prefWidth="740.0"
                spacing="16"
                style="-fx-padding: 18;">

            <children>

                <!-- ═══════════════════ HEADER ═══════════════════ -->
                <HBox
                        alignment="CENTER"
                        prefHeight="58.0"
                        prefWidth="700.0"
                        style="-fx-background-color: #7CCB6B;
                           -fx-background-radius: 16;
                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 0, 3);">
                    <children>
                        <Label
                                fx:id="lblWelcome"
                                style="-fx-text-fill: #0b0101;
                                   -fx-font-size: 24px;
                                   -fx-font-weight: bold;"
                                text="ADMIN DASHBOARD">
                            <font>
                                <Font name="System Bold" size="24.0"/>
                            </font>
                        </Label>
                    </children>
                </HBox>

                <!-- ═══════════════════ MIDDLE ROW ═══════════════════ -->
                <HBox spacing="16" prefHeight="240.0" prefWidth="700.0">

                    <children>

                        <!-- ── NAVIGATION PANEL (left) ── -->
                        <VBox
                                alignment="CENTER"
                                prefHeight="240.0"
                                prefWidth="220.0"
                                spacing="14"
                                style="-fx-background-color: white;
                                   -fx-background-radius: 16;
                                   -fx-padding: 18;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label
                                        style="-fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-text-fill: #555555;"
                                        text="MANAGE">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Label>

                                <!-- Therapists nav button -->
                                <Button
                                        fx:id="btnTherapists"
                                        onAction="#btnTherapistsOnAction"
                                        mnemonicParsing="false"
                                        prefHeight="36.0"
                                        prefWidth="180.0"
                                        style="-fx-background-color: #7CCB6B;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;"
                                        text="👨‍⚕️  Therapists">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Button>

                                <!-- Therapy Programmes nav button -->
                                <Button
                                        fx:id="btnTherapyPrograms"
                                        onAction="#btnTherapyProgramsOnAction"
                                        mnemonicParsing="false"
                                        prefHeight="36.0"
                                        prefWidth="180.0"
                                        style="-fx-background-color: #7CCB6B;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;"
                                        text="📋  Therapy Programmes">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Button>
                            </children>
                        </VBox>

                        <!-- ── REPORTS / ACTIONS PANEL (right) ── -->
                        <VBox
                                alignment="CENTER"
                                prefHeight="240.0"
                                prefWidth="462.0"
                                spacing="12"
                                style="-fx-background-color: white;
                                   -fx-background-radius: 16;
                                   -fx-padding: 18;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label
                                        style="-fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-text-fill: #555555;"
                                        text="REPORTS &amp; ANALYTICS">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Label>

                                <!-- Therapist Performance -->
                                <Button
                                        fx:id="btnTherapistPerformance"
                                        onAction="#btnTherapistPerformanceOnAction"
                                        mnemonicParsing="false"
                                        prefHeight="36.0"
                                        prefWidth="400.0"
                                        style="-fx-background-color: #2E7D32;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 20;"
                                        text="📊  Therapist Performance">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Button>

                                <!-- Therapy Session Statistics -->
                                <Button
                                        fx:id="btnSessionStatistics"
                                        onAction="#btnSessionStatisticsOnAction"
                                        mnemonicParsing="false"
                                        prefHeight="36.0"
                                        prefWidth="400.0"
                                        style="-fx-background-color: #2E7D32;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 20;"
                                        text="📈  Therapy Session Statistics">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Button>

                                <!-- View Patient Therapy History -->
                                <Button
                                        fx:id="btnPatientTherapyHistory"
                                        onAction="#btnPatientTherapyHistoryOnAction"
                                        mnemonicParsing="false"
                                        prefHeight="36.0"
                                        prefWidth="400.0"
                                        style="-fx-background-color: white;
                                           -fx-border-color: #2E7D32;
                                           -fx-border-width: 2;
                                           -fx-text-fill: #2E7D32;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 20;
                                           -fx-border-radius: 20;"
                                        text="🗂  View Patient Therapy History">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Button>
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- ═══════════════════ CHARTS ROW ═══════════════════ -->
                <HBox
                        alignment="CENTER"
                        prefHeight="290.0"
                        prefWidth="700.0"
                        spacing="16">

                    <children>

                        <!-- ── AREA CHART: Therapy Overview ── -->
                        <VBox
                                alignment="CENTER"
                                prefHeight="280.0"
                                prefWidth="338.0"
                                style="-fx-background-color: white;
                                   -fx-background-radius: 16;
                                   -fx-padding: 10;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label
                                        style="-fx-font-size: 12px;
                                           -fx-font-weight: bold;
                                           -fx-text-fill: #555555;"
                                        text="Therapy Overview">
                                    <font><Font name="System Bold" size="12.0"/></font>
                                </Label>

                                <AreaChart
                                        fx:id="therapyOverviewChart"
                                        prefHeight="240.0"
                                        prefWidth="318.0"
                                        style="-fx-background-color: transparent;">
                                    <xAxis>
                                        <CategoryAxis fx:id="xAxisOverview" side="BOTTOM"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="yAxisOverview" side="LEFT"/>
                                    </yAxis>
                                </AreaChart>
                            </children>
                        </VBox>

                        <!-- ── LINE CHART: Session Trend ── -->
                        <VBox
                                alignment="CENTER"
                                prefHeight="280.0"
                                prefWidth="338.0"
                                style="-fx-background-color: white;
                                   -fx-background-radius: 16;
                                   -fx-padding: 10;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label
                                        style="-fx-font-size: 12px;
                                           -fx-font-weight: bold;
                                           -fx-text-fill: #555555;"
                                        text="Session Trend">
                                    <font><Font name="System Bold" size="12.0"/></font>
                                </Label>

                                <LineChart
                                        fx:id="sessionChart"
                                        prefHeight="240.0"
                                        prefWidth="318.0"
                                        style="-fx-background-color: transparent;">
                                    <xAxis>
                                        <CategoryAxis fx:id="xAxisSession"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="yAxisSession"/>
                                    </yAxis>
                                </LineChart>
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>

    </children>

</AnchorPane>
