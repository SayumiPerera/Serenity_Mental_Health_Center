<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="650.0" prefWidth="1100.0" style="-fx-background-color: #F4FFF0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center.controller.MainLayoutController">

    <children>

        <!-- SIDE BAR -->
        <VBox prefHeight="650.0" prefWidth="240.0" style="-fx-background-color: #0B6E0B;                      -fx-background-radius: 0 30 30 0;">

            <children>

                <!-- TITLE -->
                <HBox alignment="CENTER" prefHeight="120.0" prefWidth="240.0">

                    <children>
                        <Label text="Serenity Therapy" textFill="WHITE" wrapText="true">

                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>

                        </Label>
                    </children>

                </HBox>

                <!-- MENU BUTTONS -->
                <VBox alignment="TOP_CENTER" prefHeight="430.0" prefWidth="240.0" spacing="18.0">

                    <children>

                        <Button fx:id="BtnHome" onAction="#BtnHomeOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: white;                                        -fx-text-fill: #0B6E0B;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Home" />

                        <Button fx:id="BtnSessionAppoinment" onAction="#BtnSessionAppoinmentOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Appointments" />

                        <Button fx:id="BtnReg" onAction="#BtnRegOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Registration" />

                        <Button fx:id="BtnPatient" onAction="#BtnPatientOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Patients" />

                        <Button fx:id="BtnPayment" onAction="#BtnPaymentOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Payments" />

                        <Button fx:id="BtnTherapist" onAction="#BtnTherapistOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Therapists" />

                        <Button fx:id="BtnTherapyPrograms" onAction="#BtnTherapyProgramsOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Programs" />

                        <Button fx:id="BtnUser" onAction="#BtnUserOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: #7CCB6B;                                        -fx-text-fill: white;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Users" />

                    </children>

                </VBox>

                <!-- LOGOUT -->
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="240.0">

                    <children>

                        <Button fx:id="BtnLogOut" onAction="#BtnLogOutOnAction" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: white;                                        -fx-text-fill: #D62828;                                        -fx-background-radius: 15;                                        -fx-font-weight: bold;                                        -fx-font-size: 14;" text="Logout" />

                    </children>

                </HBox>

            </children>

        </VBox>

        <!-- MAIN CONTENT AREA -->
        <AnchorPane fx:id="sideAncPane" layoutX="240.0" prefHeight="650.0" prefWidth="860.0" style="-fx-background-color: #F4FFF0;">

            <children>

                <!-- TOP HEADER -->
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="860.0" style="-fx-background-color: #7CCB6B; -fx-background-radius: 0 0 0 30;">

                    <children>

                        <Label layoutX="30.0" style="-fx-padding: 0 0 0 25;" text="Serenity Mental Health Therapy Center" textFill="#0c230c">

                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>

                        </Label>

                    </children>

                </HBox>

            </children>

        </AnchorPane>

    </children>

</AnchorPane>
