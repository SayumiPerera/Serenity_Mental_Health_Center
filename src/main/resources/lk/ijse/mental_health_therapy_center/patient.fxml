<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="712.0" style="-fx-background-color: #F4FFF0;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center.controller.PatientController">

    <children>

        <!-- HEADER -->

        <Label alignment="CENTER" layoutX="25.0" layoutY="20.0" prefHeight="55.0" prefWidth="660.0" style="-fx-background-color: #0B6E0B;                       -fx-background-radius: 18;                       -fx-font-weight: bold;" text="PATIENT MANAGEMENT" textFill="WHITE">

            <font>
                <Font name="System Bold" size="26.0" />
            </font>

        </Label>

        <!-- FORM CARD -->

        <VBox layoutX="25.0" layoutY="95.0" prefHeight="294.0" prefWidth="660.0" spacing="18.0" style="-fx-background-color: white;                      -fx-background-radius: 20;                      -fx-border-color: #D6EFD2;                      -fx-border-radius: 20;                      -fx-border-width: 2;">

            <children>

                <!-- ROW 1 -->

                <HBox spacing="18.0" style="-fx-padding: 20 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Patient ID" textFill="#0B6E0B" />

                                <TextField fx:id="txtId" editable="false" prefHeight="38.0" prefWidth="280.0" promptText="Auto generated ID" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Name" textFill="#0B6E0B" />

                                <TextField fx:id="txtName" prefHeight="38.0" prefWidth="280.0" promptText="Enter patient name" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 2 -->

                <HBox spacing="18.0" style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="NIC" textFill="#0B6E0B" />

                                <TextField fx:id="txtNic" prefHeight="38.0" prefWidth="280.0" promptText="Enter NIC" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Age" textFill="#0B6E0B" />

                                <TextField fx:id="txtAge" prefHeight="38.0" prefWidth="280.0" promptText="Enter age" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 3 -->

                <HBox spacing="18.0" style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Gender" textFill="#0B6E0B" />

                                <ComboBox fx:id="cmbGender" prefHeight="38.0" prefWidth="280.0" promptText="Select gender" style="-fx-background-color: #F8FFF8;                                                  -fx-border-color: #A5D6A7;                                                  -fx-border-radius: 10;                                                  -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Phone" textFill="#0B6E0B" />

                                <TextField fx:id="txtPhone" prefHeight="38.0" prefWidth="280.0" promptText="Enter phone number" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

                  <VBox spacing="8.0">

                      <children>

                          <Label style="-fx-font-weight: bold;" text="Email" textFill="#0B6E0B" />

                          <TextField fx:id="txtEmail" prefHeight="38.0" prefWidth="578.0" promptText="Enter email address" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                      </children>

                  </VBox>

                <!-- ROW 4 -->

                <HBox spacing="18.0" style="-fx-padding: 0 20 0 20;" />

            </children>

        </VBox>

        <!-- BUTTONS -->

        <HBox alignment="CENTER" layoutX="25.0" layoutY="405.0" prefHeight="50.0" prefWidth="660.0" spacing="20.0">

            <children>

                <Button fx:id="btnSave" onAction="#btnSaveOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #0B6E0B;                                -fx-text-fill: white;                                -fx-background-radius: 12;                                -fx-font-weight: bold;" text="Save" />

                <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #7CCB6B;                                -fx-text-fill: white;                                -fx-background-radius: 12;                                -fx-font-weight: bold;" text="Update" />

                <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #D62828;                                -fx-text-fill: white;                                -fx-background-radius: 12;                                -fx-font-weight: bold;" text="Delete" />

                <Button fx:id="btnClear" onAction="#btnClearOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #444444;                                -fx-text-fill: white;                                -fx-background-radius: 12;                                -fx-font-weight: bold;" text="Clear" />

            </children>

        </HBox>

        <!-- TABLE -->

        <TableView fx:id="tblPatients" layoutX="25.0" layoutY="470.0" prefHeight="160.0" prefWidth="660.0" style="-fx-background-color: white;                           -fx-border-color: #D6EFD2;                           -fx-border-width: 2;                           -fx-border-radius: 15;                           -fx-background-radius: 15;">

            <columns>

                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />

                <TableColumn fx:id="colName" prefWidth="120.0" text="Name" />

                <TableColumn fx:id="colNic" prefWidth="120.0" text="NIC" />

                <TableColumn fx:id="colAge" prefWidth="60.0" text="Age" />

                <TableColumn fx:id="colGender" prefWidth="80.0" text="Gender" />

                <TableColumn fx:id="colPhone" prefWidth="110.0" text="Phone" />

                <TableColumn fx:id="colEmail" prefWidth="110.0" text="Email" />

            </columns>

        </TableView>

    </children>

</AnchorPane>
