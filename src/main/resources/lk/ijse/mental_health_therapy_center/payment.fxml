<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0"
            prefWidth="712.0"
            style="-fx-background-color: #F4FFF0;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.mental_health_therapy_center.controller.PaymentController">

    <children>

        <!-- HEADER -->

        <Label alignment="CENTER"
               layoutX="25.0"
               layoutY="20.0"
               prefHeight="55.0"
               prefWidth="660.0"
               style="-fx-background-color: #0B6E0B;
                      -fx-background-radius: 18;
                      -fx-font-weight: bold;"
               text="PAYMENT MANAGEMENT"
               textFill="WHITE">

            <font>
                <Font name="System Bold" size="26.0"/>
            </font>

        </Label>

        <!-- FORM CARD -->

        <VBox layoutX="25.0"
              layoutY="95.0"
              prefHeight="300.0"
              prefWidth="660.0"
              spacing="18.0"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-border-color: #D6EFD2;
                     -fx-border-radius: 20;
                     -fx-border-width: 2;">

            <children>

                <!-- ROW 1 -->

                <HBox spacing="18.0"
                      style="-fx-padding: 20 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Payment ID"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtId"
                                           editable="false"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Auto generated ID"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Session ID"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtSessionId"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Enter session ID"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 2 -->

                <HBox spacing="18.0"
                      style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Patient Name"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtPatientName"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Enter patient name"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Program ID"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtProgramId"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Enter program ID"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 3 -->

                <HBox spacing="18.0"
                      style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Date"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <DatePicker fx:id="datePicker"
                                            prefHeight="38.0"
                                            prefWidth="280.0"
                                            style="-fx-background-color: #F8FFF8;
                                                   -fx-border-color: #A5D6A7;
                                                   -fx-border-radius: 10;
                                                   -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label text="Amount"
                                       textFill="#0B6E0B"
                                       style="-fx-font-weight: bold;"/>

                                <TextField fx:id="txtAmount"
                                           prefHeight="38.0"
                                           prefWidth="280.0"
                                           promptText="Enter payment amount"
                                           style="-fx-background-color: #F8FFF8;
                                                  -fx-border-color: #A5D6A7;
                                                  -fx-border-radius: 10;
                                                  -fx-background-radius: 10;"/>

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </children>

        </VBox>

        <!-- BUTTONS -->

        <HBox alignment="CENTER"
              layoutX="25.0"
              layoutY="420.0"
              prefHeight="50.0"
              prefWidth="660.0"
              spacing="20.0">

            <children>

                <Button fx:id="btnSave"
                        onAction="#btnSaveOnAction"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        style="-fx-background-color: #0B6E0B;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;
                               -fx-font-weight: bold;"
                        text="Save"/>

                <Button fx:id="btnUpdate"
                        onAction="#btnUpdateOnAction"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        style="-fx-background-color: #7CCB6B;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;
                               -fx-font-weight: bold;"
                        text="Update"/>

                <Button fx:id="btnDelete"
                        onAction="#btnDeleteOnAction"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        style="-fx-background-color: #D62828;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;
                               -fx-font-weight: bold;"
                        text="Delete"/>

                <Button fx:id="btnClear"
                        onAction="#btnClearOnAction"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        style="-fx-background-color: #444444;
                               -fx-text-fill: white;
                               -fx-background-radius: 12;
                               -fx-font-weight: bold;"
                        text="Clear"/>

            </children>

        </HBox>

        <!-- TABLE -->

        <TableView fx:id="tblPayments"
                   layoutX="25.0"
                   layoutY="495.0"
                   prefHeight="135.0"
                   prefWidth="660.0"
                   style="-fx-background-color: white;
                          -fx-border-color: #D6EFD2;
                          -fx-border-width: 2;
                          -fx-border-radius: 15;
                          -fx-background-radius: 15;">

            <columns>

                <TableColumn fx:id="colId"
                             prefWidth="70.0"
                             text="ID"/>

                <TableColumn fx:id="colSessionId"
                             prefWidth="90.0"
                             text="Session ID"/>

                <TableColumn fx:id="colPatientName"
                             prefWidth="140.0"
                             text="Patient Name"/>

                <TableColumn fx:id="colProgramId"
                             prefWidth="90.0"
                             text="Program ID"/>

                <TableColumn fx:id="colDate"
                             prefWidth="120.0"
                             text="Date"/>

                <TableColumn fx:id="colAmount"
                             prefWidth="120.0"
                             text="Amount"/>

            </columns>

        </TableView>

    </children>

</AnchorPane>