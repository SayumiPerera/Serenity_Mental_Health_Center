<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="712.0" style="-fx-background-color: #F4FFF0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center.controller.TherapistController">

    <children>

        <!-- TITLE -->

        <Label alignment="CENTER" layoutX="25.0" layoutY="20.0" prefHeight="55.0" prefWidth="660.0" style="-fx-background-color: linear-gradient(to right, #16A34A, #22C55E); -fx-background-radius: 18;" text="THERAPIST MANAGEMENT" textFill="WHITE">

            <font>
                <Font name="System Bold" size="26.0" />
            </font>

        </Label>

        <!-- FORM -->

        <VBox layoutX="25.0" layoutY="95.0" prefHeight="260.0" prefWidth="660.0" spacing="18.0" style="-fx-background-color: white;                      -fx-background-radius: 20;                      -fx-border-color: #D6EFD2;                      -fx-border-width: 2;                      -fx-border-radius: 20;">

            <children>

                <!-- ROW 1 -->

                <HBox spacing="18.0" style="-fx-padding: 20 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Therapist ID" textFill="#0B6E0B" />

                                <TextField fx:id="txtId" editable="false" prefHeight="38.0" prefWidth="280.0" promptText="Auto generated ID" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Therapist Name" textFill="#0B6E0B" />

                                <TextField fx:id="txtName" prefHeight="38.0" prefWidth="280.0" promptText="Enter therapist name" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 2 -->

                <HBox spacing="18.0" style="-fx-padding: 0 20 0 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Email" textFill="#0B6E0B" />

                                <TextField fx:id="txtEmail" prefHeight="38.0" prefWidth="280.0" promptText="Enter email" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Phone" textFill="#0B6E0B" />

                                <TextField fx:id="txtPhone" prefHeight="38.0" prefWidth="280.0" promptText="Enter phone number" style="-fx-background-color: #F8FFF8;                                                   -fx-border-color: #A5D6A7;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <!-- ROW 3 -->

                <HBox spacing="18.0" style="-fx-padding: 0 20 20 20;">

                    <children>

                        <VBox spacing="8.0">

                            <children>

                                <Label style="-fx-font-weight: bold;" text="Therapy Program" textFill="#0B6E0B" />

                                <ComboBox fx:id="cmbProgram" prefHeight="38.0" prefWidth="580.0" promptText="Select therapy program" style="-fx-background-color: #F8FFF8;                                                  -fx-border-color: #A5D6A7;                                                  -fx-border-radius: 10;                                                  -fx-background-radius: 10;" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </children>

        </VBox>

        <!-- BUTTONS -->

        <HBox alignment="CENTER" layoutX="25.0" layoutY="380.0" prefHeight="50.0" prefWidth="660.0" spacing="20.0">

            <children>

                <Button fx:id="btnAdd" onAction="#btnAddOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #0B6E0B;                                -fx-text-fill: white;                                -fx-background-radius: 12;" text="Add" />

                <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #7CCB6B;                                -fx-text-fill: white;                                -fx-background-radius: 12;" text="Update" />

                <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #D62828;                                -fx-text-fill: white;                                -fx-background-radius: 12;" text="Delete" />

                <Button fx:id="btnClear" onAction="#btnClearOnAction" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #444444;                                -fx-text-fill: white;                                -fx-background-radius: 12;" text="Clear" />

            </children>

        </HBox>

        <!-- TABLE -->

        <TableView fx:id="tblTherapist" layoutX="25.0" layoutY="455.0" prefHeight="165.0" prefWidth="660.0" style="-fx-background-color: white;                           -fx-border-color: #D6EFD2;                           -fx-border-width: 2;                           -fx-border-radius: 15;                           -fx-background-radius: 15;">

            <columns>

                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />

                <TableColumn fx:id="colName" prefWidth="170.0" text="Name" />

                <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email" />

                <TableColumn fx:id="colPhone" prefWidth="120.0" text="Phone" />

                <TableColumn fx:id="colProgram" prefWidth="120.0" text="Program" />

            </columns>

        </TableView>

    </children>

</AnchorPane>
