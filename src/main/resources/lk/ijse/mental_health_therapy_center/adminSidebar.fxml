<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="650.0" prefWidth="712.0" style="-fx-background-color: #F5F7FA;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center.controller.AdminSidebarController">

    <children>

        <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="712.0" spacing="18" style="-fx-padding: 20;">

            <children>

                <!-- HEADER -->
                <HBox alignment="CENTER" prefHeight="60.0" prefWidth="670.0" style="-fx-background-color: #7CCB6B; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">

                    <children>
                        <Label style="-fx-text-fill: black; -fx-font-size: 28px; -fx-font-weight: bold;" text="ADMIN DASHBOARD" textFill="#0b0101">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                    </children>

                </HBox>

                <!-- MAIN CHART -->
                <HBox alignment="CENTER" prefHeight="230.0" prefWidth="575.0">

                    <children>

                              <!-- QUICK ACTIONS -->
                        <VBox alignment="CENTER" prefHeight="262.0" prefWidth="674.0" spacing="15" style="-fx-background-color: white;                                      -fx-background-radius: 18;                                      -fx-padding: 15;                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">

                                  <children>
                        <Button mnemonicParsing="false" prefHeight="30.0" prefWidth="160.0" style="-fx-background-color: #7CCB6B; -fx-background-radius: 10;" text="Therapists">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>

                                      <!-- TOP ICON ROW -->
                                <HBox alignment="CENTER" spacing="12" />
                        <Button mnemonicParsing="false" prefHeight="30.0" prefWidth="160.0" style="-fx-background-color: #7CCB6B; -fx-background-radius: 10;" text="Therapy Programmes">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Button>

                                      <!-- SECOND ICON ROW -->
                                <HBox alignment="CENTER" spacing="12" />

                                      <!-- BUTTONS -->
                                <Button fx:id="btnPayments" onAction="#btnPaymentsOnAction" prefHeight="36.0" prefWidth="190.0" style="-fx-background-color: #2E7D32;                                                -fx-text-fill: white;                                                -fx-font-weight: bold;                                                -fx-background-radius: 20;" text="Therapist Perfomance" />

                                      <Button fx:id="btnReports" onAction="#btnReportsOnAction" prefHeight="36.0" prefWidth="190.0" style="-fx-background-color: #2E7D32; -fx-border-color: #2E7D32; -fx-border-width: 2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20;" text="Therapy Session Statistics" />

                                      <Button fx:id="btnHistory" onAction="#btnHistoryOnAction" prefHeight="36.0" prefWidth="190.0" style="-fx-background-color: white;                                                -fx-border-color: #2E7D32;                                                -fx-border-width: 2;                                                -fx-text-fill: #2E7D32;                                                -fx-font-weight: bold;                                                -fx-background-radius: 20;                                                -fx-border-radius: 20;" text="View Patient Therapy History" />

                                  </children>

                              </VBox>

                    </children>

                </HBox>

                <!-- LOWER SECTION -->
                <HBox alignment="CENTER" prefHeight="260.0" prefWidth="670.0" spacing="18">

                    <children>

                        <!-- SESSION CHART -->
                        <VBox alignment="CENTER" prefHeight="250.0" prefWidth="390.0" spacing="10" style="-fx-background-color: white;                                      -fx-background-radius: 18;                                      -fx-padding: 12;                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">
                     <children>
      
                              <AreaChart fx:id="therapyOverviewChart" prefHeight="248.0" prefWidth="364.0" style="-fx-background-color: white;                                           -fx-background-radius: 18;                                           -fx-padding: 10;                                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12,0,0,3);">
      
                                  <xAxis>
                                      <CategoryAxis side="BOTTOM" fx:id="xAxisOverview" />
                                  </xAxis>
      
                                  <yAxis>
                                      <NumberAxis fx:id="yAxisOverview" side="LEFT" />
                                  </yAxis>
      
                              </AreaChart>
                     </children>

                        </VBox>

                          <LineChart fx:id="sessionChart" prefHeight="200.0" prefWidth="360.0">

                              <xAxis>
                                  <CategoryAxis fx:id="xAxisSession" />
                              </xAxis>

                              <yAxis>
                                  <NumberAxis fx:id="yAxisSession" />
                              </yAxis>

                          </LineChart>

                    </children>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>
