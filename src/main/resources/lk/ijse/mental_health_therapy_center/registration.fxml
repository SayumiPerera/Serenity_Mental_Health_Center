<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="650.0" prefWidth="712.0" style="-fx-background-color: #F6FFF8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center.controller.RegistrationController">

    <children>

        <VBox layoutX="18.0" layoutY="18.0" prefHeight="614.0" prefWidth="676.0" spacing="15.0">

            <!-- Header -->
            <HBox alignment="CENTER" prefHeight="65.0" prefWidth="676.0" style="-fx-background-color: black; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);">

                <children>
                    <Label style="-fx-font-weight: bold;" text="Patient Registration" textFill="#49d99b">
                        <font>
                            <Font size="30.0" />
                        </font>
                    </Label>
                </children>
            </HBox>

            <!-- Top Buttons -->
            <HBox alignment="CENTER" prefHeight="45.0" spacing="20.0">

                <children>

                    <Button fx:id="BtnViewAll" mnemonicParsing="false" onAction="#BtnViewAllOnAction" prefHeight="38.0" prefWidth="170.0" style="-fx-background-color: #2D6A4F;                                    -fx-background-radius: 10;                                    -fx-text-fill: white;                                    -fx-font-weight: bold;" text="View All" />

                    <Button fx:id="BtnPayment" mnemonicParsing="false" onAction="#BtnPaymentOnAction" prefHeight="38.0" prefWidth="150.0" style="-fx-background-color: #40916C;                                    -fx-background-radius: 10;                                    -fx-text-fill: white;                                    -fx-font-weight: bold;" text="Payments" />
                </children>
            </HBox>

            <!-- Registration Info -->
            <HBox prefHeight="35.0" spacing="50.0">

                <children>

                    <HBox spacing="10.0">
                        <children>
                            <Label style="-fx-font-weight: bold;" text="Registration ID:" textFill="#1B4332" />

                            <Label fx:id="TxtRegId" text="R-001" textFill="#2D6A4F" />
                        </children>
                    </HBox>

                    <HBox spacing="10.0">
                        <children>

                            <Label style="-fx-font-weight: bold;" text="Date:" textFill="#1B4332" />

                            <DatePicker fx:id="datePicker" prefHeight="32.0" prefWidth="160.0" style="-fx-background-radius: 8;                                                -fx-border-radius: 8;                                                -fx-border-color: #95D5B2;                                                -fx-background-color: white;" />
                        </children>
                    </HBox>

                </children>
            </HBox>

            <Separator />

            <!-- Main Form -->
            <VBox spacing="18.0" style="-fx-background-color: white;                          -fx-background-radius: 15;                          -fx-padding: 20;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

                <children>

                    <!-- Patient -->
                    <HBox alignment="CENTER_LEFT" spacing="15.0">

                        <children>

                            <Label prefWidth="130.0" style="-fx-font-weight: bold;" text="Patient" textFill="#1B4332" />

                            <ComboBox fx:id="CmbPatient" onAction="#CmbPatientOnAction" prefHeight="35.0" prefWidth="220.0" promptText="Select patient" style="-fx-background-radius: 8;                                              -fx-border-radius: 8;                                              -fx-border-color: #95D5B2;" />

                            <Label prefWidth="120.0" style="-fx-font-weight: bold;" text="Patient Name" textFill="#1B4332" />

                            <TextField fx:id="TxtIdName" editable="false" prefHeight="35.0" prefWidth="220.0" promptText="Patient name" style="-fx-background-radius: 8;                                               -fx-border-radius: 8;                                               -fx-border-color: #95D5B2;" />
                        </children>
                    </HBox>

                    <!-- Program -->
                    <HBox alignment="CENTER_LEFT" spacing="15.0">

                        <children>

                            <Label prefWidth="130.0" style="-fx-font-weight: bold;" text="Therapy Program" textFill="#1B4332" />

                            <ComboBox fx:id="CmbTherapyPrograms" onAction="#CmbTherapyProgramsOnAction" prefHeight="35.0" prefWidth="220.0" promptText="Select program" style="-fx-background-radius: 8;                                              -fx-border-radius: 8;                                              -fx-border-color: #95D5B2;" />

                            <Label prefWidth="120.0" style="-fx-font-weight: bold;" text="Program ID" textFill="#1B4332" />

                            <Label fx:id="TxtProId" text="P-001" textFill="#2D6A4F" />
                        </children>
                    </HBox>

                    <!-- Fee -->
                    <HBox alignment="CENTER_LEFT" spacing="15.0">

                        <children>

                            <Label prefWidth="130.0" style="-fx-font-weight: bold;" text="Program Fee" textFill="#1B4332" />

                            <Label fx:id="TxtFee" style="-fx-font-weight: bold;" text="25000.00" textFill="#2D6A4F" />

                            <Label prefWidth="140.0" style="-fx-font-weight: bold;" text="Remaining Balance" textFill="#1B4332" />

                            <TextField fx:id="TxtBalance" prefHeight="35.0" prefWidth="180.0" promptText="0.00" style="-fx-background-radius: 8;                                               -fx-border-radius: 8;                                               -fx-border-color: #95D5B2;" />
                        </children>
                    </HBox>

                    <!-- Buttons -->
                    <HBox alignment="CENTER" prefHeight="50.0" spacing="20.0">

                        <children>

                            <Button fx:id="BtnRegister" mnemonicParsing="false" onAction="#BtnRegisterOnAction" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #2D6A4F;                                            -fx-background-radius: 10;                                            -fx-text-fill: white;                                            -fx-font-weight: bold;" text="Register" />

                            <Button fx:id="BtnUpdate" mnemonicParsing="false" onAction="#BtnUpdateOnAction" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #40916C;                                            -fx-background-radius: 10;                                            -fx-text-fill: white;                                            -fx-font-weight: bold;" text="Update" />

                            <Button fx:id="BtnDelete" mnemonicParsing="false" onAction="#BtnDeleteOnAction" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #D00000;                                            -fx-background-radius: 10;                                            -fx-text-fill: white;                                            -fx-font-weight: bold;" text="Delete" />

                            <Button fx:id="BtnReset" mnemonicParsing="false" onAction="#BtnResetOnAction" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #74C69D;                                            -fx-background-radius: 10;                                            -fx-text-fill: white;                                            -fx-font-weight: bold;" text="Reset" />
                        </children>
                    </HBox>

                </children>
            </VBox>

            <!-- Table -->
            <TableView fx:id="TblRegistration" onMouseClicked="#TblRegistrationOnAction" prefHeight="260.0" prefWidth="676.0" style="-fx-background-color: white;                               -fx-background-radius: 15;                               -fx-border-color: #B7E4C7;                               -fx-border-radius: 15;">

                <columns>

                    <TableColumn fx:id="ColId" prefWidth="90.0" text="Reg ID" />

                    <TableColumn fx:id="ColPatientId" prefWidth="120.0" text="Patient" />

                    <TableColumn fx:id="ColProgram" prefWidth="150.0" text="Program" />

                    <TableColumn fx:id="ColAdvance" prefWidth="100.0" text="Balance" />

                    <TableColumn fx:id="ColPatient" prefWidth="120.0" text="Patient Name" />

                    <TableColumn fx:id="ColProgramId" prefWidth="90.0" text="Program ID" />

                    <TableColumn fx:id="ColDate" prefWidth="120.0" text="Date" />

                </columns>
            </TableView>

        </VBox>

    </children>
</AnchorPane>
