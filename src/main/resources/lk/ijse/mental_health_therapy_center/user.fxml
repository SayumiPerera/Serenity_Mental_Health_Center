<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="650.0" prefWidth="712.0" style="-fx-background-color: #F8FFFB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.mental_health_therapy_center.controller.UserController">

    <children>

        <!-- Main Layout -->
        <VBox layoutX="20.0" layoutY="20.0" prefHeight="610.0" prefWidth="672.0" spacing="20.0">

            <!-- Header -->
            <HBox alignment="CENTER" prefHeight="70.0" style="-fx-background-color: black; -fx-background-radius: 18;">

                <children>
                    <Label style="-fx-font-weight: bold;" text="USER MANAGEMENT" textFill="#45d798">
                        <font>
                            <Font size="28.0" />
                        </font>
                    </Label>
                </children>
            </HBox>

            <!-- ID Row -->
            <HBox alignment="CENTER_LEFT" spacing="40.0">

                <children>

                    <HBox spacing="10.0">
                        <children>
                            <Label style="-fx-font-weight: bold;" text="User ID :" textFill="#166534" />

                            <Label fx:id="LblId" text="U-001" textFill="#166534" />
                        </children>
                    </HBox>

                </children>
            </HBox>

            <!-- Form Card -->
            <VBox spacing="18.0" style="-fx-background-color: white;                          -fx-background-radius: 20;                          -fx-border-radius: 20;                          -fx-border-color: #BBF7D0;                          -fx-border-width: 1.5;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">

                <padding>
                    <Insets bottom="25" left="25" right="25" top="25" />
                </padding>

                <children>

                    <!-- Row 1 -->
                    <HBox spacing="20.0">

                        <VBox spacing="8.0">
                            <children>

                                <Label style="-fx-font-weight: bold;" text="Name" textFill="#166534" />

                                <TextField fx:id="TxtName" prefWidth="280.0" promptText="Enter full name" style="-fx-background-color: #F0FDF4;                                                   -fx-text-fill: #166534;                                                   -fx-prompt-text-fill: #6B7280;                                                   -fx-border-color: #86EFAC;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>

                                <Label style="-fx-font-weight: bold;" text="Username" textFill="#166534" />

                                <TextField fx:id="TxtUsername" prefWidth="280.0" promptText="Enter username" style="-fx-background-color: #F0FDF4;                                                   -fx-text-fill: #166534;                                                   -fx-prompt-text-fill: #6B7280;                                                   -fx-border-color: #86EFAC;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>
                        </VBox>

                    </HBox>

                    <!-- Row 2 -->
                    <HBox spacing="20.0">

                        <VBox spacing="8.0">
                            <children>

                                <Label style="-fx-font-weight: bold;" text="Email" textFill="#166534" />

                                <TextField fx:id="TxtEmail" prefWidth="280.0" promptText="Enter email" style="-fx-background-color: #F0FDF4;                                                   -fx-text-fill: #166534;                                                   -fx-prompt-text-fill: #6B7280;                                                   -fx-border-color: #86EFAC;                                                   -fx-border-radius: 10;                                                   -fx-background-radius: 10;" />

                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>

                                <Label style="-fx-font-weight: bold;" text="Role" textFill="#166534" />

                                <ComboBox fx:id="CmbRole" prefWidth="280.0" promptText="Select role" style="-fx-background-color: #F0FDF4;                                                  -fx-border-color: #86EFAC;                                                  -fx-border-radius: 10;                                                  -fx-background-radius: 10;" />

                            </children>
                        </VBox>

                    </HBox>

                    <!-- Row 3 -->
                    <HBox spacing="20.0">

                        <VBox spacing="8.0">
                            <children>

                                <Label style="-fx-font-weight: bold;" text="Password" textFill="#166534" />

                                <PasswordField fx:id="TxtPassword" prefWidth="280.0" promptText="Enter password" style="-fx-background-color: #F0FDF4;                                                       -fx-text-fill: #166534;                                                       -fx-prompt-text-fill: #6B7280;                                                       -fx-border-color: #86EFAC;                                                       -fx-border-radius: 10;                                                       -fx-background-radius: 10;" />

                            </children>
                        </VBox>

                    </HBox>

                    <!-- Buttons -->
                    <HBox alignment="CENTER" prefHeight="60.0" spacing="18.0">

                        <children>

                            <Button fx:id="BtnAdd" onAction="#BtnAddOnAction" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: #22C55E;                                            -fx-font-weight: bold;                                            -fx-background-radius: 12;" text="Add" textFill="WHITE" />

                            <Button fx:id="BtnUpdate" onAction="#BtnUpdateOnAction" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: #16A34A;                                            -fx-font-weight: bold;                                            -fx-background-radius: 12;" text="Update" textFill="WHITE" />

                            <Button fx:id="BtnDelete" onAction="#BtnDeleteOnAction" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: #DC2626;                                            -fx-font-weight: bold;                                            -fx-background-radius: 12;" text="Delete" textFill="WHITE" />

                            <Button fx:id="BtnReset" onAction="#BtnResetOnAction" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: #F59E0B;                                            -fx-font-weight: bold;                                            -fx-background-radius: 12;" text="Reset" textFill="WHITE" />

                        </children>
                    </HBox>

                </children>
            </VBox>

            <!-- Table -->
            <TableView fx:id="TblUsers" onMouseClicked="#TblUserOnAction" prefHeight="250.0" prefWidth="672.0" style="-fx-background-color: white;                               -fx-border-color: #BBF7D0;                               -fx-border-radius: 15;                               -fx-background-radius: 15;                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <columns>

                    <TableColumn fx:id="ColId" prefWidth="70.0" text="ID" />

                    <TableColumn fx:id="ColName" prefWidth="160.0" text="Name" />

                    <TableColumn fx:id="ColUsername" prefWidth="140.0" text="Username" />

                    <TableColumn fx:id="ColEmail" prefWidth="180.0" text="Email" />

                    <TableColumn fx:id="ColRole" prefWidth="110.0" text="Role" />

                </columns>

            </TableView>

        </VBox>

    </children>

</AnchorPane>
